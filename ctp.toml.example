# Contextual Trust Protocol — example configuration.
#
# Semantics are deny-by-default everywhere:
#   * unknown keys are rejected at startup,
#   * tools are denied unless explicitly enabled,
#   * the guard backend must be chosen consciously (no default),
#   * listeners bind loopback unless an operator decides otherwise.

[challenge]
# Hard cap enforced before any rule runs; oversize payloads block outright.
max_payload_bytes = 32768

# Data-driven pattern rules: add detection patterns without recompiling.
# Patterns use Rust `regex` syntax and are validated at startup.
[[challenge.rules]]
id = "instruction_override_en"
pattern = '(?i)ignore\s+(all\s+)?(previous|prior|above)\s+instructions'
action = "block"
severity = "high"
description = "Classic instruction-override phrasing"

[[challenge.rules]]
id = "role_marker_forgery"
pattern = '(?im)^\s*(system|assistant|developer)\s*:'
action = "flag"
severity = "medium"
description = "Role-marker lines inside data payloads"

# Plaintext prompt-exfiltration. Gated on direct address ("your") so it fires
# on the imperative attack ("output your system prompt") but not on text that
# merely discusses the topic ("how attackers reveal the system prompt"). What
# is catchable here at ~16 us must not depend on the fallible multi-second
# guard (see docs/benchmarks/2026-06-cpu-qwen.md, where a 0.5B passed this).
[[challenge.rules]]
id = "prompt_exfiltration"
pattern = '(?i)\b(reveal|repeat|print|output|show|disclose|dump|leak)\s+(me\s+)?your\s+(full\s+|complete\s+|exact\s+|entire\s+|verbatim\s+|initial\s+|original\s+|hidden\s+|system\s+)*(system\s+prompt|prompt|instructions|directives)\b'
action = "block"
severity = "high"
description = "Imperative request to disclose the system prompt/instructions"

# Role/identity reassignment. Gated on the "you are now ... mode/DAN" frame,
# which is the strong discriminator from descriptive uses of "developer mode".
[[challenge.rules]]
id = "role_reassignment"
pattern = '(?i)\byou\s+are\s+(now\s+)?(in\s+)?(a\s+|the\s+)?((developer|debug|admin|god|root|sudo|maintenance|unrestricted|unfiltered)\s+mode|dan|jailbroken|jailbreak\s+mode)\b'
action = "block"
severity = "high"
description = "Attempt to reassign the reader's role/mode (DAN, developer mode)"

# Safety/guardrail-off phrasings. FLAG, not block: "safety filters are
# disabled" is also a legitimate description (an incident report, a log), so
# this annotates and feeds the multi-turn anomaly ledger rather than blocking
# on its own. The actual attack above ("you are now in developer mode") is
# caught by role_reassignment; this is the additive signal.
[[challenge.rules]]
id = "safety_override"
pattern = '(?i)\b(safety|content|security|moderation)\s+(filters?|guards?|guardrails?|checks?|controls?|features?|measures?|settings?)\s+(\w+\s+){0,2}?(off|disabled|removed|bypassed|deactivated)\b'
action = "flag"
severity = "medium"
description = "Safety/guardrail-disabled phrasing (advisory; ambiguous in prose)"

[guard]
# REQUIRED. "mock" performs NO real classification — tests only.
# Production deployments use "llama" with a local GGUF model.
backend = "mock"
socket_path = "/run/ctp/guard.sock"
# model_path = "/var/lib/ctp/models/guard.gguf"   # required for "llama"
# Client-side, authoritative, fail-closed budget per window. 500 ms suits a
# small model on a GPU; CPU-only inference of a 0.5B-class model needs seconds
# per verdict, so testing on CPU uses 10000. Lower this back toward ~500 on
# accelerated hardware — a loose timeout widens the window a slow/hung guard
# stays in the path before failing closed.
timeout_ms = 10000
max_window_bytes = 2048     # also enforced server-side
window_overlap_bytes = 256  # windows overlap so boundary-split text is seen whole
max_concurrent = 4
prompt_version = "guard_system_v1"

[kernel]
anomaly_threshold = 3.0  # cumulative session score that blocks the session
anomaly_decay = 0.5      # per-turn multiplicative decay, within (0, 1]
anomaly_floor = 0.5      # decay can't push a tainted session below this; within [0, threshold)
flag_weight = 0.5        # score per advisory flag
max_sessions = 10000

# Tools are DENIED unless listed here with `enabled = true`.
[kernel.tools.web_fetch]
enabled = true
max_result_bytes = 262144

[orchestrator]
listen = "127.0.0.1:50051"          # external gRPC endpoint
metrics_listen = "127.0.0.1:9464"   # Prometheus exporter
